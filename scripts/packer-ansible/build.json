{
  "packer": [
    {
      "required_plugins": [
        {
          "docker": {
            "source": "github.com/hashicorp/docker",
            "version": ">= 1.0.0"
          },
          "ansible": {
            "source": "github.com/hashicorp/ansible",
            "version": ">= 1.1.0"
          }
        }
      ]
    }
  ],
  "variable": {
    "image_name": {
      "type": "string",
      "default": "my-app"
    },
    "image_tag": {
      "type": "string",
      "default": "1.0"
    },
    "base_image": {
      "type": "string",
      "default": "ubuntu:24.04"
    }
  },
  "source": [
    {
      "type": "docker",
      "name": "ubuntu",
      "image": "{{user `base_image`}}",
      "commit": true,
      "changes": [
        "EXPOSE 8080",
        "WORKDIR /app",
        "ENV APP_ENV=production",
        "CMD [\"/usr/bin/python3\", \"/app/main.py\"]"
      ]
    }
  ],
  "build": [
    {
      "name": "my-app-build",
      "sources": ["source.docker.ubuntu"],
      "provisioner": [
        {
          "type": "shell",
          "environment_vars": [
            "DEBIAN_FRONTEND=noninteractive",
            "TZ=UTC"
          ],
          "inline": [
            "apt-get update -y",
            "apt-get install -y python3 python3-pip python3-venv",
            "mkdir -p /tmp/.ansible/tmp"
          ]
        },
        {
          "type": "ansible",
          "playbook_file": "./playbook.yml",
          "use_proxy": false,
          "user": "root",
          "inventory_file_template": "default ansible_host={{ .ID }}\n",
          "extra_arguments": [
            "-e", "ansible_connection=community.docker.docker",
            "-e", "ansible_remote_tmp=/tmp/.ansible/tmp",
            "-e", "ansible_python_interpreter=/usr/bin/python3"
          ]
        }
      ],
      "post-processors": [
        {
          "type": "docker-tag",
          "repository": "{{user `image_name`}}",
          "tags": ["{{user `image_tag`}}", "latest"]
        }
      ]
    }
  ]
}
