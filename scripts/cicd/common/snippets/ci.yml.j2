  lint:
    name: "${{ matrix.name }}"
    runs-on: ubuntu-22.04
    strategy:
      fail-fast: <= github.fail_fast | default(True) | lower =>
      matrix:
        include:
<% for item in github.lint_matrix %>
          - name: "<= item.name =>"
            # ansible: "<= item.ansible =>"
            ansible: "<= item.ansible_core =>"
            ansible_lint: "<= item.ansible_lint =>"
            python: "<= item.python =>"
            venv: "<= item.venv =>"

<% endfor %>

    steps:

      - name: Check out the codebase.
        uses: actions/checkout@v6
        with:
          path: "${{ github.repository }}"

      - name: Set up Python3.
        uses: actions/setup-python@v6
        with:
          python-version: "${{ matrix.python }}"

<% if github.deploy_keys is defined %>
      - name: Set-up SSH agent
        uses: webfactory/ssh-agent@v0.7.0
        with:
          ssh-private-key: |
<% for key in github.deploy_keys %>
            ${{ secrets.<= key => }}
<% endfor %>
<% endif %>

      - name: Show runner info
        run: |

          hostname="$(hostname -f)"
          eval os_name=$(awk -F= '/^NAME=/ {print $2}' /etc/os-release)
          eval os_version=$(awk -F= '/^VERSION=/ {print $2}' /etc/os-release)
          os="$os_name $os_version"
          user="$(id -un)"
          python=$(which python3)

          echo "hostname : $hostname"
          echo "user     : $user"
          echo "os       : $os"
          echo "python   : $python ($(python3 --version))"

<% include snippet_path + 'deployment-key.yml.j2' %>

<% include snippet_path + 'fix-runner.yml.j2' %>

<% include snippet_path + 'apparmor.yml.j2' %>

<% include snippet_path + 'cicd-tools.yml.j2' %>

<% include snippet_path + 'venv.yml.j2' %>

<% include snippet_path + 'ansible-galaxy.yml.j2' %>

<% include snippet_path + 'show-versions.yml.j2' %>

      - name: Lint code.
        run: |
          set -e
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          yamllint .
          /usr/local/bin/ansible-lint.sh -f readable
