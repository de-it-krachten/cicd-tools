---

name: CI

on:
  pull_request:
  push:
    branches-ignore:
      - master
      - main
  workflow_dispatch:
  schedule:
    - cron: "0 7 * * 1"

defaults:
  run:
    working-directory: "<= github.owner =>/<= github.repo =>"

<% if github.vars is defined %>
env:
<% for key, value in github['vars'].items() %>
  <= key =>: "<= value =>"
<% endfor %>
<% endif %>

jobs:

  lint:
    name: "${{ matrix.name }}"
    runs-on: ubuntu-22.04
    strategy:
      fail-fast: <= github.fail_fast | default(True) | lower =>
      matrix:
        include:
<% for item in github.lint_matrix %>
          - name: "<= item.name =>"
            # ansible: "<= item.ansible =>"
            ansible: "<= item.ansible_core =>"
            ansible_lint: "<= item.ansible_lint =>"
            python: "<= item.python =>"
            venv: "<= item.venv =>"

<% endfor %>

    steps:

      - name: Check out the codebase.
        uses: actions/checkout@v6
        with:
          path: "${{ github.repository }}"

      - name: Set up Python3.
        uses: actions/setup-python@v6
        with:
          python-version: "${{ matrix.python }}"

<% if github.deploy_keys is defined %>
      - name: Set-up SSH agent
        uses: webfactory/ssh-agent@v0.7.0
        with:
          ssh-private-key: |
<% for key in github.deploy_keys %>
            ${{ secrets.<= key => }}
<% endfor %>
<% endif %>

      - name: Configure deployment key
        run: |
          [[ ! -d ~/.ssh ]] && mkdir -m 700 ~/.ssh
          echo "$DEPLOYMENT_KEY" | base64 -d > ~/.ssh/id_rsa
          chmod 600 ~/.ssh/id_rsa
        env:
          DEPLOYMENT_KEY: ${{ secrets.DEPLOYMENT_KEY }}

      - name: Show runner info
        run: |

          hostname="$(hostname -f)"
          eval os_name=$(awk -F= '/^NAME=/ {print $2}' /etc/os-release)
          eval os_version=$(awk -F= '/^VERSION=/ {print $2}' /etc/os-release)
          os="$os_name $os_version"
          user="$(id -un)"
          python=$(which python3)

          echo "hostname : $hostname"
          echo "user     : $user"
          echo "os       : $os"
          echo "python   : $python ($(python3 --version))"

      - name: Disable specific apparmor profiles
        run: |
          sudo ln -s /etc/apparmor.d/usr.sbin.mysqld /etc/apparmor.d/disable/
          sudo apparmor_parser -R /etc/apparmor.d/usr.sbin.mysqld
<% for prof in github.apparmor_profiles | default([]) %>
          sudo ln -s /etc/apparmor.d/<= prof => /etc/apparmor.d/disable/
          sudo apparmor_parser -R /etc/apparmor.d/<= prof =>
<% endfor %>

      - name: Install test dependencies.
        run: |
          sudo rm -f /usr/bin/yq

      - name: Retrieve & install wrapper scripts
        run: |

          cicd_version=${{ vars.cicd_version }}

          # Install requirements
          echo "== Installing dependencies"
          sudo apt install curl jq -y

          # If no package version was given, get the latest
          if [[ -z $cicd_version ]]
          then
            echo "== Retrieving cicd_tools version"

            # API uri to query
            api_url=https://api.github.com/repos/de-it-krachten/cicd-tools/releases/latest

            # Get latest release download URL for .deb asset
            cicd_version=$(curl -s $api_url | jq -r '.tag_name' | sed "s/null//" | sed "s/^v//")

          fi

          # If still no version found, fall back onto a default
          if [[ -z $cicd_version ]]
          then
            echo "== Fallback to default version '2.0.0'"
            cicd_version=2.0.0
          fi

          # Construct url
          release_url=https://github.com/de-it-krachten/cicd-tools/releases/download/v${cicd_version}/cicd-tools_${cicd_version}.deb

          # Download package
          echo "== Downloading package '$release_url'"
          file=$(basename $release_url)
          curl -s -L -o $file -s $release_url || exit 1

          echo "== Installing package '$file'"
          sudo dpkg -i $file || exit 1

      - name: Update wrapper scripts
        if: vars.UPDATE_CICD_TOOLS == 'yes'
        run: |
          set -e
          prefix=/opt/cicd-tools
          [[ $(id -un) != root ]] && sudo=sudo
          $sudo apt install git rsync -y
          git clone https://github.com/de-it-krachten/cicd-tools.git /tmp/cicd-tools
          commit=$(git -C /tmp/cicd-tools rev-parse HEAD)
          echo "commit: $commit"
          $sudo rsync -cav /tmp/cicd-tools/scripts/* ${prefix}/ | grep -v "/$"
          for f in /opt/cicd-tools/bin/*
          do
            $sudo ln -fs $f /usr/local/bin/$(basename $f)
          done
          $sudo chown -h -R root:root ${prefix}

      - name: Install tools in their virtual environments
        run: |
          set -e
          [[ $(id -un) != root ]] && sudo=sudo
          ansible="${{ matrix.venv }}"
          export VENV_LIST="yq e2j2 jinjanator $ansible"
          /opt/cicd-tools/python/python-setup-venvs.sh -v --sudo /usr/local/venv

      - name: Install required galaxy collections
        run: |
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          /usr/local/bin/ansible-collections.sh

      - name: Show component versions
        run: |
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          ansible --version
          ansible-lint --version
          yamllint --version

      - name: Lint code.
        run: |
          set -e
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          yamllint .
          /usr/local/bin/ansible-lint.sh -f readable

<% if github.molecule|bool %>
  molecule:
    name: "${{ matrix.name }}"
    runs-on: "${{ matrix.runs_on }}"
    needs: lint
    # continue-on-error: ${{ matrix.continue_on_error }}
    strategy:
      fail-fast: <= github.fail_fast | default(True) | lower =>
      matrix:
        include:
<% for distro in platforms|dict2items %>
<% if distro.value.ci|bool %>
          - name: <= distro.key =>
            runs_on: <= distro.value.github.runs_on | default('ubuntu-22.04') =>
            distro: <= distro.key =>
            playbook: converge.yml
<% if distro.key | regex_search('(rhel8|centos8|oraclelinux8|almalinux8|rockylinux8|olam8|opensuse15|sles15)') %>
            venv: "ansiblecore216"
            ansible: "ansible-core>2.16,<2.17"
            ansible_lint: "ansible-lint>6,<7"
            python: "3.12"
<% else %>
            venv: "ansiblecore218"
            ansible: "ansible-core>2.18,<2.19"
            ansible_lint: "ansible-lint"
            python: "3.13"
<% endif %>
            hetznercloud: <= True if distro.value.molecule.hetznercloud is defined else False =>

<% endif %>
<% endfor %>

    steps:

      - name: Check out the codebase.
        uses: actions/checkout@v6
        with:
          path: "${{ github.repository }}"

<% if github.ssh_access is defined and github.ssh_access | bool %>
      - name: Setup upterm session
        uses: lhotari/action-upterm@v1
        with:
          ## limits ssh access and adds the ssh public key for the user which triggered the workflow
          limit-access-to-actor: true
          ## limits ssh access and adds the ssh public keys of the listed GitHub users
          # limit-access-to-users: mark-it-kracht
<% endif %>

      - name: Set up Python3.
        uses: actions/setup-python@v6
        with:
          python-version: "${{ matrix.python }}"

<% if github.deploy_keys is defined %>
      - name: Set-up SSH agent
        uses: webfactory/ssh-agent@v0.7.0
        with:
          ssh-private-key: |
<% for key in github.deploy_keys %>
            ${{ secrets.<= key => }}
<% endfor %>
<% endif %>

      - name: Configure deployment key
        run: |
          [[ ! -d ~/.ssh ]] && mkdir -m 700 ~/.ssh
          echo "$DEPLOYMENT_KEY" | base64 -d > ~/.ssh/id_rsa
          chmod 600 ~/.ssh/id_rsa
        env:
          DEPLOYMENT_KEY: ${{ secrets.DEPLOYMENT_KEY }}

      - name: Show runner info
        run: |

          hostname="$(hostname -f)"
          eval os_name=$(awk -F= '/^NAME=/ {print $2}' /etc/os-release)
          eval os_version=$(awk -F= '/^VERSION=/ {print $2}' /etc/os-release)
          os="$os_name $os_version"
          user="$(id -un)"
          python=$(which python3)

          echo "hostname : $hostname"
          echo "user     : $user"
          echo "os       : $os"
          echo "python   : $python ($(python3 --version))"

      - name: Disable specific apparmor profiles
        run: |
          sudo ln -s /etc/apparmor.d/usr.sbin.mysqld /etc/apparmor.d/disable/
          sudo apparmor_parser -R /etc/apparmor.d/usr.sbin.mysqld
<% for prof in github.apparmor_profiles | default([]) %>
          sudo ln -s /etc/apparmor.d/<= prof => /etc/apparmor.d/disable/
          sudo apparmor_parser -R /etc/apparmor.d/<= prof =>
<% endfor %>

      - name: Install test dependencies.
        run: |
          sudo rm -f /usr/bin/yq

      - name: Retrieve & install wrapper scripts
        run: |

          cicd_version=${{ vars.cicd_version }}

          # Install requirements
          echo "== Installing dependencies"
          sudo apt install curl jq -y

          # If no package version was given, get the latest
          if [[ -z $cicd_version ]]
          then
            echo "== Retrieving cicd_tools version"

            # API uri to query
            api_url=https://api.github.com/repos/de-it-krachten/cicd-tools/releases/latest

            # Get latest release download URL for .deb asset
            cicd_version=$(curl -s $api_url | jq -r '.tag_name' | sed "s/null//" | sed "s/^v//")

          fi

          # If still no version found, fall back onto a default
          if [[ -z $cicd_version ]]
          then
            echo "== Fallback to default version '2.0.0'"
            cicd_version=2.0.0
          fi

          # Construct url
          release_url=https://github.com/de-it-krachten/cicd-tools/releases/download/v${cicd_version}/cicd-tools_${cicd_version}.deb

          # Download package
          echo "== Downloading package '$release_url'"
          file=$(basename $release_url)
          curl -s -L -o $file -s $release_url || exit 1

          echo "== Installing package '$file'"
          sudo dpkg -i $file || exit 1

      - name: Update wrapper scripts
        if: vars.UPDATE_CICD_TOOLS == 'yes'
        run: |
          set -e
          prefix=/opt/cicd-tools
          [[ $(id -un) != root ]] && sudo=sudo
          $sudo apt install git rsync -y
          git clone https://github.com/de-it-krachten/cicd-tools.git /tmp/cicd-tools
          commit=$(git -C /tmp/cicd-tools rev-parse HEAD)
          echo "commit: $commit"
          $sudo rsync -cav /tmp/cicd-tools/scripts/* ${prefix}/ | grep -v "/$"
          for f in /opt/cicd-tools/bin/*
          do
            $sudo ln -fs $f /usr/local/bin/$(basename $f)
          done
          $sudo chown -h -R root:root ${prefix}

      - name: Install tools in their virtual environments
        run: |
          set -e
          [[ $(id -un) != root ]] && sudo=sudo
          ansible="${{ matrix.venv }}"
          export VENV_LIST="yq e2j2 jinjanator $ansible"
          /opt/cicd-tools/python/python-setup-venvs.sh --sudo /usr/local/venv

      - name: Install required galaxy collections
        run: |
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          /usr/local/bin/ansible-collections.sh

      - name: Set-up github runner
        run: |
          sudo modprobe ip6table_filter

      - name: Show component versions
        run: |
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          set -vx
          pip3 list
          ansible-galaxy collection list
          python3 --version
          ansible --version
          ansible-lint --version
          yamllint --version
          molecule --version

      - name: Run Molecule tests.
        run: |
          ansible="${{ matrix.venv }}"
          source /usr/local/venv/$ansible/bin/activate
          /usr/local/bin/molecule-test.sh -A
        env:
          PY_COLORS: '1'
          ANSIBLE_FORCE_COLOR: '1'
          MOLECULE_DISTRO: ${{ matrix.distro }}
          MOLECULE_PLAYBOOK: ${{ matrix.playbook }}
<% if github.ssh_access is defined and github.ssh_access | bool %>
          MOLECULE_WAIT_AFTER_ERROR: '900'
<% endif %>
          HCLOUD_TOKEN: ${{ secrets.HCLOUD_TOKEN }}
          MOLECULE_DRIVER: ${{ vars.MOLECULE_DRIVER }}
<% endif %>
